{
    "adoServerUrl": "https://ado.contoso.com",
    "collections": {
        "GAMS": {
            "pat": "YOUR_PAT_HERE",
            "description": "GAMS collection — legacy TFVC repos"
        },
        "TargetCollection": {
            "pat": "YOUR_PAT_HERE",
            "description": "Target collection for reorganized repos"
        }
    },
    "outputDirectory": "./output",
    "logDirectory": "./logs",
    "gitTfsPath": null,
    "authorMappingFile": null,
    "defaultBranch": "main",
    "github": {
        "enterpriseUrl": "https://github.contoso.com",
        "apiUrl": "https://github.contoso.com/api/v3",
        "pat": "YOUR_GITHUB_PAT_HERE",
        "defaultOrg": "Contoso"
    },
    "migrationDefaults": {
        "includeHistory": true,
        "historyDepthLimit": null,
        "timeoutMinutes": 120,
        "stallTimeoutMinutes": 30,
        "excludePatterns": [
            "**/bin/**",
            "**/obj/**",
            "**/packages/**",
            "**/.vs/**",
            "**/node_modules/**"
        ],
        "gitLfsExtensions": [
            "*.dll",
            "*.exe",
            "*.zip",
            "*.nupkg",
            "*.pdb"
        ],
        "cleanupBinaries": true
    }
}
