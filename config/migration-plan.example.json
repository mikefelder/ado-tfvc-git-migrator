{
    "migrations": [
        {
            "name": "Legacy App — Full Repo Migration",
            "type": "full",
            "sourceCollection": "GAMS",
            "sourceProject": "LegacyApp",
            "tfvcPath": "$/LegacyApp",
            "gitHubOrg": "Contoso",
            "gitHubRepo": "legacy-app",
            "description": "Full TFVC migration of LegacyApp"
        },
        {
            "name": "MonoRepo — Split Into Services",
            "type": "split",
            "sourceCollection": "GAMS",
            "sourceProject": "MonoRepo",
            "tfvcPath": "$/MonoRepo",
            "splits": [
                {
                    "tfvcFolder": "$/MonoRepo/ServiceA",
                    "gitHubOrg": "Contoso",
                    "gitHubRepo": "service-a"
                },
                {
                    "tfvcFolder": "$/MonoRepo/ServiceB",
                    "gitHubOrg": "Contoso",
                    "gitHubRepo": "service-b"
                },
                {
                    "tfvcFolder": "$/MonoRepo/SharedLib",
                    "gitHubOrg": "Contoso",
                    "gitHubRepo": "shared-lib"
                }
            ]
        },
        {
            "name": "OldProject Component — Move to ModernApps then GitHub",
            "type": "move",
            "sourceCollection": "GAMS",
            "sourceProject": "OldProject",
            "tfvcPath": "$/OldProject/Component",
            "targetCollection": "TargetCollection",
            "targetProject": "Platform",
            "targetRepoName": "component",
            "gitHubOrg": "Contoso",
            "gitHubRepo": "component",
            "description": "Moved from GAMS to ModernApps, then to GitHub"
        },
        {
            "name": "Existing Git Repo — Move to GAMS-GIT-Repos",
            "type": "move",
            "sourceCollection": "LegacyApps",
            "sourceProject": "SharedServices",
            "sourceRepoType": "Git",
            "sourceRepoName": "billing-api",
            "targetCollection": "GAMS-GIT-Repos",
            "targetProject": "SharedServices",
            "targetRepoName": "billing-api",
            "description": "Moves an existing Git repo between ADO collections without TFVC conversion"
        }
    ]
}
